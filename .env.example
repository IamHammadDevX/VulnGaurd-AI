# ─────────────────────────────────────────────────────────────
# VulnGuard AI — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
# Port the API server listens on (default: 8080)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Anthropic AI ─────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
# On Replit these are auto-provisioned via the Anthropic AI Integration.
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
