# ─────────────────────────────────────────────────────────────
# VulnGuard AI — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
# Port the API server listens on (default: 8080)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Keep-alive for Render free tier (prevents cold starts).
# Set to 'true' to enable self-pinging every 5 minutes.
# Alternative: use UptimeRobot (free) to ping /api/healthz externally.
# See KEEP_ALIVE_SETUP.md for details.
ENABLE_KEEP_ALIVE=false

# ── OpenRouter AI ────────────────────────────────────────────
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet
# Optional metadata headers for OpenRouter analytics
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=VulnGuard AI

# ── Supabase Database (Postgres) ─────────────────────────────
# Use Supabase Transaction Pooler URI or Direct URI.
# Example: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional fallback used by the db package if DATABASE_URL is not set.
SUPABASE_DB_URL=

# Optional: only required if you migrate auth to Supabase Auth later.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend-exposed Supabase values for Vite app auth pages.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Email RESEND SETUP
RESEND_API_KEY=re_xxx
EMAIL_FROM_AUTH=auth@mail.thevulnguardai.tech
EMAIL_FROM_NO_REPLY=no-reply@mail.thevulnguardai.tech
EMAIL_FROM_SUPPORT=support@thevulnguardai.tech
EMAIL_FROM_BILLING=billing@thevulnguardai.tech
SUPPORT_INBOX=support@thevulnguardai.tech
APP_BASE_URL=https://www.thevulnguardai.tech